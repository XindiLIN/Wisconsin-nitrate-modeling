plot_roc_by_threshold <- function(thresh_val) {
# Find keys in your list that end with the threshold (e.g., "_10")
keys <- grep(paste0("_", thresh_val, "$"), names(roc_list), value = TRUE)
# Select the ROC objects and rename them for the legend
current_rocs <- roc_list[keys]
names(current_rocs) <- name_map[gsub(paste0("_", thresh_val), "", keys)]
# Plot using ggroc
ggroc(current_rocs, legacy.axes = TRUE, linewidth = 1) +
geom_abline(slope = 1, intercept = 0, linetype = "dashed", alpha = 0.5) +
scale_color_brewer(palette = "Set1") +
theme_minimal() +
labs(
title = paste("ROC Curves at", thresh_val, "mg/L Threshold"),
color = "Method",
x = "1 - Specificity (False Positive Rate)",
y = "Sensitivity (True Positive Rate)"
)
}
# Generate plots
p_roc_2  <- plot_roc_by_threshold(2)
p_roc_10 <- plot_roc_by_threshold(10)
